NODE_ENV=development
PORT=5000

# MySQL (local or AWS RDS)
DB_HOST=community-db.c5asquws6grq.ap-south-1.rds.amazonaws.com
DB_PORT=3306
DB_NAME=community_system
DB_USER=admin
DB_PASSWORD=admin12345
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true

# Controls Sequelize sync() on startup.
# In production prefer migrations, but for learning/initial setup you can enable:
DB_SYNC=false

# ONE-TIME fix for complaints schema mismatch:
# Drops + recreates ONLY the `complaints` table using the current Sequelize model.
FORCE_RECREATE_COMPLAINTS=false

# JWT
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Uploads (local now, S3-ready later)
UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://localhost:5000

# Email (Nodemailer - use Gmail App Password or SES later)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=you@example.com
EMAIL_PASS=your_app_password
EMAIL_FROM_NAME=Community Reporting System
EMAIL_FROM_ADDRESS=no-reply@example.com
